{
  "name": "personal-website-solid",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint & knip",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "preview": "vite preview"
  },
  "dependencies": {
    "@solid-primitives/i18n": "^2.2.1",
    "@solidjs/router": "^0.16.1",
    "solid-js": "^1.9.13",
    "solid-motionone": "^1.0.4",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "knip": "^6.14.1",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-solid": "^2.11.12"
  },
  "overrides": {
    "vite": "^8.0.0-beta.13"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "bun run lint",
    "*": "bun run format"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "bun"
}
